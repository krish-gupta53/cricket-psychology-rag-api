# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_HOST=https://your-index-host.svc.pinecone.io

# ── API access protection (set this in Render env vars, never commit the real value)
APP_API_KEY=your_strong_secret_key_here

# ── Optional: Pinecone / embedding ────────────────────────────────────────────
PINECONE_NAMESPACE=content-automate
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Optional: Per-node model overrides ───────────────────────────────────────
# brief_model and query_model use gpt-4.1-mini (fast, cost-effective)
# angle_model and final_model use gpt-4.1 (highest quality judgment + generation)
# summary_model uses gpt-4.1-mini (simple summarisation)
BRIEF_MODEL=gpt-4.1-mini
QUERY_MODEL=gpt-4.1-mini
ANGLE_MODEL=gpt-4.1
FINAL_MODEL=gpt-4.1
SUMMARY_MODEL=gpt-4.1-mini

# ── Optional: retrieval tuning ────────────────────────────────────────────────
TOP_K_PER_QUERY=5
FINAL_CHUNK_COUNT=9
